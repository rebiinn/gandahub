# Local development: use this when backend runs with "php artisan serve" (port 8000)
VITE_API_URL=http://localhost:8000/api/v1

# If backend is on XAMPP/WAMP (e.g. http://localhost/ganda_h/public), use:
# VITE_API_URL=http://localhost/ganda_h/public/api/v1
# Then restart the frontend dev server (npm run dev).

# For production, set VITE_API_URL in Vercel Environment Variables.
